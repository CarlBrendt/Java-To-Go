@startuml
start
    /'act_0'/:act_0;
    /'If_0'/if (name == exit) then (exit)
        /'act_1'/:act_1;
        /'act_2'/:act_2;
    else (нет)
        /'act_3'/:act_3;
    endif
    /'act_4'/:act_4;
stop
@enduml
/'
